# ── Supabase ─────────────────────────────────────────────────────
# Your Supabase project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (NEVER expose to browser — server only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────
# Used for signing internal tokens / tRPC auth (min 32 chars)
APP_SECRET=your-super-secret-key-min-32-characters-long

# Your deployed URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── AI Providers ─────────────────────────────────────────────────
# OpenRouter — PRIMARY provider (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=AIza...

# DeepSeek (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-...

# ── Admin ─────────────────────────────────────────────────────────
# Email address of the first admin user
# This user's role will be set to 'admin' on first signup
ADMIN_EMAIL=admin@yourdomain.com
