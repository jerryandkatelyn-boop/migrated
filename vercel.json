{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "functions": {
    "app/api/stream/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/trpc/[trpc]/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/stream/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-transform" },
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ]
}
